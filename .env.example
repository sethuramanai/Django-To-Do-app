# ===== DJANGO SETTINGS =====
SECRET_KEY=replace-this-with-a-secure-secret
DEBUG=True
ALLOWED_HOSTS=127.0.0.1,localhost

# ===== SUPABASE DATABASE =====
# Get your credentials from: https://supabase.com/dashboard
# Project Settings → Database → Connection string

# Option 1: Direct connection (for most deployments)
# Replace YOUR-PASSWORD with your Supabase database password
# Replace PROJECT-ID with your Supabase project ID (from the connection string)
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-ID].supabase.co:5432/postgres?sslmode=require

# Option 2: Session pooler (RECOMMENDED FOR WINDOWS LOCAL DEVELOPMENT)
# This avoids connection timeout issues on Windows
# Copy the full URL from Supabase Dashboard: Settings → Database → Connection string → Session pooler
DATABASE_URL=postgresql://postgres.[PROJECT-ID]:[YOUR-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres?sslmode=require

# Example (replace with your actual credentials):
# DATABASE_URL=postgresql://postgres.abc123xyz:mypassword123@aws-0-us-east-1.pooler.supabase.com:5432/postgres?sslmode=require
